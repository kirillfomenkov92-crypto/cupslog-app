generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  VIEWER
}

model Tournament {
  id          String           @id @default(cuid())
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime?
  status      TournamentStatus @default(UPCOMING)
  createdAt   DateTime         @default(now())
  teams       Team[]
  matches     Match[]
}

enum TournamentStatus {
  UPCOMING
  LIVE
  COMPLETED
}

model Team {
  id           String     @id @default(cuid())
  name         String
  tag          String
  logoUrl      String?
  tournament   Tournament @relation(fields: [tournamentId], references: [id])
  tournamentId String
  matchesAsT1  Match[]    @relation("Team1")
  matchesAsT2  Match[]    @relation("Team2")
  wins         Match[]    @relation("Winner")
  players      Player[]
}

model Player {
  id        String  @id @default(cuid())
  nickname  String
  realName  String?
  steamId   String?
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId    String
}

model Match {
  id           String      @id @default(cuid())
  tournament   Tournament  @relation(fields: [tournamentId], references: [id])
  tournamentId String
  team1        Team        @relation("Team1", fields: [team1Id], references: [id])
  team1Id      String
  team2        Team        @relation("Team2", fields: [team2Id], references: [id])
  team2Id      String
  winner       Team?       @relation("Winner", fields: [winnerId], references: [id])
  winnerId     String?
  team1Score   Int         @default(0)
  team2Score   Int         @default(0)
  format       MatchFormat @default(BO1)
  status       MatchStatus @default(PENDING)
  webhookToken String?     @unique
  mapPool      String[]    @default([])
  scheduledAt  DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  maps         MatchMap[]
}

enum MatchFormat {
  BO1
  BO3
  BO5
}

enum MatchStatus {
  PENDING
  LIVE
  COMPLETED
  CANCELLED
}

model MatchMap {
  id         String  @id @default(cuid())
  match      Match   @relation(fields: [matchId], references: [id])
  matchId    String
  mapName    String
  order      Int
  team1Score Int     @default(0)
  team2Score Int     @default(0)
  winnerId   String?
}
